# MemeTrader AI — Environment Configuration
# ─────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# The system works WITHOUT any API keys using free public endpoints.
# Paid keys just unlock additional data sources.

# ─── Database ────────────────────────────────────────────────────────────────
# Docker Compose default (works out of the box):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/memetrader
# Local dev (replace 'postgres' host with 'localhost'):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/memetrader

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Local dev: REDIS_URL=redis://localhost:6379/0

# ─── Worker Timing ───────────────────────────────────────────────────────────
SIGNAL_REFRESH_INTERVAL_SECONDS=30    # Scan frequency in seconds (min: 30)
COINGECKO_MAX_PAGES=4                 # 250 coins per page

# ─── Free API Keys (optional) ────────────────────────────────────────────────
# CoinGecko Pro — free tier works without this, Pro gives higher rate limits
COINGECKO_API_KEY=

# ─── Paid API Keys (all optional — skip gracefully without them) ─────────────

# BIRDEYE — Best for Solana: new token launches, whale detection, holder data
# Replaces the broken Pump.fun API. Free tier at: https://birdeye.so/
BIRDEYE_API_KEY=

# MORALIS — Multi-chain: ETH/BSC/Base token gainers and trending tokens
# Free tier: 40k compute units/day at: https://moralis.io/
MORALIS_API_KEY=

# BITQUERY — Real-time GraphQL: Pump.fun on-chain events, dev wallet detection
# Free tier at: https://bitquery.io/
BITQUERY_API_KEY=

# ALCHEMY — EVM infrastructure: token prices, whale transfer detection
# Free tier: 300M compute units/month at: https://alchemy.com/
ALCHEMY_API_KEY=

# ─── Frontend ────────────────────────────────────────────────────────────────
# API URL as seen from the BROWSER (baked into Next.js at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Risk Thresholds ─────────────────────────────────────────────────────────
WHALE_CONCENTRATION_THRESHOLD=0.30   # Flag if top wallets hold > 30% of supply
SPIKE_THRESHOLD=0.50                  # Flag if price spikes > 50% suddenly
MIN_LIQUIDITY_USD=50000               # Min liquidity for CoinGecko signal gen
DEBUG=false
